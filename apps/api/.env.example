# Template for apps/api/.env — copy to .env and fill in real values.
# This file is safe to commit (no real secrets). The real .env stays
# git-ignored (see repo .gitignore) both locally and on the deploy server.

# Anthropic Claude API key used by the AI agent pipeline.
ANTHROPIC_API_KEY=

# SQLite database path (relative to the prisma/ directory in local dev).
DATABASE_URL=file:./dev.db

# ---- Authentication ----
# Secret used to sign session JWTs. Use a long random value (e.g. `openssl
# rand -base64 48`) in any real deployment — never reuse the dev value.
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=brokerino_session
# Set to "true" once the API is served over HTTPS (true in production/behind
# the Cloudflare tunnel).
AUTH_COOKIE_SECURE=false

# Optional: bootstraps a single username/password admin account on server
# startup (only created if no account with this email exists yet).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Google OAuth "Sign in with Google" (login + signup). Leave blank to disable
# the Google option; the login/signup screens will only offer
# username/password.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Where to redirect the browser after a successful Google sign-in. In
# production, set this to the live Cloudflare tunnel URL.
APP_BASE_URL=http://localhost:4173

# ---- SMTP (outbound email) ----
# Leave SMTP_HOST blank to disable sending; emails are logged to the console
# instead.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ChatTrader <no-reply@ChatTrader.local>"

# ---- YouTube source crawling ----
# Optional: routes only the YouTube caption/transcript HTTP requests through a proxy (e.g. a
# residential/mobile proxy service URL like http://user:pass@host:port). YouTube blocks/limits
# unauthenticated caption requests from known datacenter/VPS IP ranges (Hetzner included) more
# aggressively than residential IPs; if episodes that fetch fine locally consistently fail with
# "No transcript/captions available" only when deployed, set this to bypass the IP-based block.
# Leave blank to make requests directly (no proxy).
YOUTUBE_PROXY_URL=

# Optional: YouTube session cookie (raw `Cookie:` header value) to bypass "LOGIN_REQUIRED"
# responses YouTube sometimes returns for caption/transcript requests from IPs it doesn't trust
# (confirmed to happen on this Hetzner deployment). Export cookies from a browser signed into a
# Google account (e.g. via the "Get cookies.txt LOCALLY" extension, exporting for youtube.com) and
# paste the resulting Cookie header value here as one line, e.g.:
#   YOUTUBE_COOKIE=SID=...; HSID=...; SSID=...; APISID=...; SAPISID=...; LOGIN_INFO=...
# Cheaper to try than YOUTUBE_PROXY_URL, but not permanent - Google may invalidate exported
# cookies over time (especially once it notices automated traffic from an unfamiliar server IP),
# so this may need periodic re-export. Leave blank to send requests unauthenticated.
YOUTUBE_COOKIE=

# ---- Text-to-speech (Studio audio podcasts) ----
# OpenAI API key used only for rendering discussion audio. Leave blank to disable.
OPENAI_API_KEY=
# Google Cloud Text-to-Speech REST API key (Cloud Console -> enable "Cloud
# Text-to-Speech API" -> create API key). Preferred over OpenAI when both are
# set - useful when corporate policy blocks the OpenAI API. Neural2 voices,
# English + German.
GOOGLE_TTS_API_KEY=
# Where rendered mp3 files are stored (relative to apps/api).
TTS_AUDIO_DIR=./data/audio
