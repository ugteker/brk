generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  displayName  String?
  role                        String   @default("user")
  emailVerified               Boolean   @default(false)
  emailVerificationToken      String?   @unique
  emailVerificationExpiresAt  DateTime?
  locked                      Boolean   @default(false)
  passwordResetToken          String?   @unique
  passwordResetExpiresAt      DateTime?
  // Monthly Claude-spend budget in USD - null means unlimited. When month-to-date estimated cost
  // across the user's agents reaches this, new runs fail fast with budget_exceeded.
  monthlyBudgetUsd            Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Agent {
  id              String      @id @default(cuid())
  ownerUserId     String
  name            String
  description     String      @default("")
  characterType   String      @default("summarizer")
  promptConfigJson String     @default("{}")
  status          String      @default("active")
  preferencesJson String      @default("{}")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  sources     AgentSource[]
  runs        AgentRun[]
  promptVersions AgentPromptVersion[]
  runReports  AgentRunReport[]
  sourceCursors AgentSourceCursor[]
  sourceCrawlConfigs AgentSourceCrawlConfig[]
  playbooks   Playbook[]
  accessGrants AccessGrant[] @relation("AccessGrantGranteeAgent")
  resourceAccessGrants AccessGrant[] @relation("AccessGrantResourceAgent")
  marketplacePublications MarketplacePublication[]
}

model AgentSource {
  id      String  @id @default(cuid())
  agentId   String
  type    String
  value   String
  enabled Boolean @default(true)
  frequencyMinutes Int @default(60)
  maxItems Int @default(1)
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Restrict)
}

model AgentRun {
  id           String   @id @default(cuid())
  agentId        String
  playbookId   String?
  scheduledFor DateTime
  status       String
  phase        String?
  workerId     String?
  retryCount   Int      @default(0)
  errorCode    String?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  agent          Agent      @relation(fields: [agentId], references: [id], onDelete: Restrict)
  playbook       Playbook?  @relation(fields: [playbookId], references: [id], onDelete: Restrict)
  artifacts    AgentRunArtifact[]
  report       AgentRunReport?

  @@unique([agentId, scheduledFor])
}

model AgentPromptVersion {
  id           String   @id @default(cuid())
  agentId        String
  version      Int
  model        String
  systemPrompt String
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  agent          Agent      @relation(fields: [agentId], references: [id], onDelete: Restrict)
  reports      AgentRunReport[]

  @@unique([agentId, version])
}

model AgentRunArtifact {
  id          String   @id @default(cuid())
  agentId       String
  agentRunId    String
  kind        String
  sourceRef   String
  payloadJson String
  fidelity    String
  createdAt   DateTime @default(now())
  agentRun      AgentRun   @relation(fields: [agentRunId], references: [id], onDelete: Restrict)
}

model AgentRunReport {
  id                 String   @id @default(cuid())
  agentId              String
  agentRunId           String   @unique
  promptVersionId    String
  summary            String
  reportJson         String?
  sourceWarningsJson String
  needsHumanReview   Boolean
  model              String?
  promptVersionNumber Int?
  inputTokens        Int?
  outputTokens       Int?
  estimatedCostUsd   Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  agent                Agent              @relation(fields: [agentId], references: [id], onDelete: Restrict)
  agentRun             AgentRun           @relation(fields: [agentRunId], references: [id], onDelete: Restrict)
  promptVersion      AgentPromptVersion @relation(fields: [promptVersionId], references: [id], onDelete: Restrict)
  signals            AgentSignal[]
}

model AgentSignal {
  id            String   @id @default(cuid())
  agentRunReportId String
  symbol        String
  side          String
  confidence    Int
  rationale     String
  citationsJson String
  createdAt     DateTime @default(now())
  report        AgentRunReport @relation(fields: [agentRunReportId], references: [id], onDelete: Restrict)
}

model ReportChatMessage {
  id        String   @id @default(cuid())
  reportId  String
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([reportId, userId, createdAt])
}

model WatchlistEntry {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  createdAt DateTime @default(now())

  @@unique([userId, symbol])
  @@index([symbol])
}

model AgentSourceCursor {
  id                  String    @id @default(cuid())
  agentId             String
  sourceValue         String
  strategy            String
  seenItemIdsJson     String?
  lastItemPublishedAt DateTime?
  lastContentHash     String?
  lastCrawledAt       DateTime?
  updatedAt           DateTime  @updatedAt
  agent               Agent     @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@unique([agentId, sourceValue])
}

model AgentSourceCrawlConfig {
  id                   String    @id @default(cuid())
  agentId              String
  sourceValue          String
  siteType             String
  configJson           String
  inspectedAt          DateTime  @default(now())
  inspectionModel      String?
  confidence           Float?
  lastReinspectionAt   DateTime?
  reinspectionCount24h Int       @default(0)
  agent                Agent     @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@unique([agentId, sourceValue])
}

model Source {
  id         String   @id @default(cuid())
  ownerUserId String
  type       String
  value      String
  status     String   @default("active")
  configJson String   @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  playbooks  PlaybookSource[]
  accessGrants AccessGrant[]
  marketplacePublications MarketplacePublication[]
  items      SourceItem[]

  @@unique([ownerUserId, type, value])
}

model Playbook {
  id                String   @id @default(cuid())
  agentId           String
  name              String
  description       String   @default("")
  mode              String   @default("interval")
  intervalMinutes   Int?
  dailyTime         String?
  timezone          String?
  daysOfWeekJson    String?
  nextRunAt         DateTime
  enabled           Boolean  @default(true)
  notificationsEnabled Boolean @default(true)
  digestFrequency   String   @default("immediate")
  lastDigestSentAt  DateTime?
  executionMode     String   @default("latest_only")
  maxSourcesPerRun  Int      @default(3)
  maxItemsPerSource Int      @default(1)
  recipientsJson    String   @default("[]")
  followTargetType  String?
  followTargetKey   String?
  followTargetTitle String?
  language          String   @default("en")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Restrict)
  sources           PlaybookSource[]
  runs              AgentRun[]
  accessGrants      AccessGrant[]
  marketplacePublications MarketplacePublication[]

  @@index([agentId, enabled])
}

model PlaybookSource {
  id         String   @id @default(cuid())
  playbookId String
  sourceId   String
  enabled    Boolean  @default(true)
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  playbook   Playbook @relation(fields: [playbookId], references: [id], onDelete: Restrict)
  source     Source   @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  @@unique([playbookId, sourceId])
  @@index([sourceId, enabled])
}

model AccessGrant {
  id            String    @id @default(cuid())
  grantedByUserId String
  granteeUserId String?
  granteeAgentId String?
  resourceType  String
  resourceId    String
  permission    String
  agentId       String?
  sourceId      String?
  playbookId    String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  granteeAgent  Agent?    @relation("AccessGrantGranteeAgent", fields: [granteeAgentId], references: [id], onDelete: Restrict)
  agent         Agent?    @relation("AccessGrantResourceAgent", fields: [agentId], references: [id], onDelete: Restrict)
  source        Source?   @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  playbook      Playbook? @relation(fields: [playbookId], references: [id], onDelete: Restrict)

  @@index([resourceType, resourceId])
  @@index([granteeUserId, resourceType, resourceId])
  @@index([granteeAgentId, resourceType, resourceId])
}

model MarketplacePublication {
  id             String    @id @default(cuid())
  publisherUserId String
  resourceType   String
  resourceId     String
  title          String
  summary        String    @default("")
  visibility     String    @default("private")
  status         String    @default("draft")
  publishedAt    DateTime?
  retiredAt      DateTime?
  agentId        String?
  sourceId       String?
  playbookId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  agent          Agent?    @relation(fields: [agentId], references: [id], onDelete: Restrict)
  source         Source?   @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  playbook       Playbook? @relation(fields: [playbookId], references: [id], onDelete: Restrict)

  @@index([resourceType, resourceId])
  @@index([publisherUserId, status, visibility])
}

model SourceItem {
  id          String   @id @default(cuid())
  sourceId    String
  title       String
  content     String
  link        String
  publishedAt DateTime
  createdAt   DateTime @default(now())
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Discussion {
  id                String   @id @default(cuid())
  ownerUserId       String
  name              String
  description       String   @default("")
  format            String   @default("free_form")
  formatConfigJson  String   @default("{}")
  scheduleJson      String?
  syntheticSourceId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  participants      DiscussionParticipant[]
  runs              DiscussionRun[]
}

model DiscussionParticipant {
  id             String   @id @default(cuid())
  discussionId   String
  agentId        String
  role           String   @default("speaker")
  voiceId        String   @default("alloy")
  speakerOrder   Int      @default(0)
  reportIdsJson  String   @default("[]")
  discussion     Discussion       @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  turns          DiscussionTurn[]
}

model DiscussionRun {
  id                    String    @id @default(cuid())
  discussionId          String
  status                String    @default("pending")
  triggeredBy           String    @default("manual")
  errorMessage          String?
  startedAt             DateTime?
  completedAt           DateTime?
  syntheticSourceItemId String?
  audioUrl              String?
  evidenceSnapshotJson  String?
  createdAt             DateTime  @default(now())
  discussion            Discussion       @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  turns                 DiscussionTurn[]
}

model DiscussionTurn {
  id               String   @id @default(cuid())
  discussionRunId  String
  participantId    String
  turnIndex        Int
  segmentLabel     String?
  content          String
  audioUrl         String?
  createdAt        DateTime @default(now())
  run              DiscussionRun         @relation(fields: [discussionRunId], references: [id], onDelete: Cascade)
  participant      DiscussionParticipant @relation(fields: [participantId], references: [id], onDelete: Restrict)
}

model RealtimeEvent {
  id        Int      @id @default(autoincrement())
  userId    String
  topic     String
  entityId  String?
  createdAt DateTime @default(now())

  @@index([userId, id])
  @@index([createdAt])
}
